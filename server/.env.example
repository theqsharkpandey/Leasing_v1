PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/leasing_world
CLIENT_URL=http://localhost:3000
JWT_SECRET=change-me-to-a-random-string
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Brevo (recommended for cloud hosting — uses HTTP API, no SMTP port restrictions)
BREVO_API_KEY=xkeysib-your_brevo_api_key
BREVO_FROM_EMAIL=info@theleasingworld.com
# SMTP fallback (for local dev or hosting that allows SMTP ports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Your App <your_email@gmail.com>
